.env
.env.*
!.env.example

backend/venv/
backend/**/__pycache__/
backend/**/*.pyc

frontend/.next/
frontend/node_modules/

.vscode/
.DS_Store
Thumbs.db
*.log

# ignore all data by default
data/
backend/data/*

# allow production output folder
!backend/data/
!backend/data/output/

# allow only v2 files needed by app
backend/data/output/*
!backend/data/output/*_v2.csv
!backend/data/output/*_v2.geojson

# keep folder placeholders if needed
!backend/data/.gitkeep
!backend/data/output/.gitkeep

# ignore generated report/temp artifacts
backend/data/output/_report_*
backend/data/output/_temp_*
backend/data/output/temp_*
backend/data/output/*.gpkg
backend/data/output/*.png